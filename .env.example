# Brookelyn standalone runtime
# Copy to .env.local for local development, or set as deploy-time secrets.

# --- Supabase ---
# Example: https://your-project-ref.supabase.co
SUPABASE_URL=
# Browser/client key. In current Supabase projects this is typically the new
# sb_publishable_* key. This repo reads SUPABASE_PUBLISHABLE_KEY directly.
SUPABASE_PUBLISHABLE_KEY=
# Vite client runtime variables. Keep these equal to the values above.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Trusted server-only key. In current Supabase projects this is typically the
# new sb_secret_* key. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- App base URLs / auth redirects ---
# Public app origin used for magic-link redirects and docs/examples
APP_URL=http://127.0.0.1:4173
# Optional browser-visible app origin override used by the Sources UI to display webhook URLs.
# If unset in the browser, the app falls back to window.location.origin.
VITE_APP_URL=http://127.0.0.1:4173
# Optional legacy/public alias for the same browser-visible app origin.
VITE_PUBLIC_APP_URL=http://127.0.0.1:4173
# Comma-separated extra allowed redirect URLs if you deploy previews or multiple domains.
# These must also be added in Supabase Auth redirect settings.
APP_REDIRECT_URLS=http://127.0.0.1:4173,http://localhost:4173

# --- AI / enrichment dependencies ---
# Anthropic API key used by lead extraction, enrichment, and outreach generation
ANTHROPIC_API_KEY=
# Optional model override for low-cost/default workloads
ANTHROPIC_MODEL_CHEAP=claude-3-5-haiku-latest
# Optional model override for heavier reasoning workloads
ANTHROPIC_MODEL_COMPLEX=claude-3-7-sonnet-latest
# Bright Data Web Access API key for LinkedIn contact discovery
BRIGHTDATA_API_KEY=
# Example: linkedin_v1
BRIGHTDATA_SERP_ZONE=
# Optional but required for article scraping/import enrichment flows
FIRECRAWL_API_KEY=

# --- Public endpoint secrets ---
# Required by /api/public/inbound-email via x-inbound-secret header or ?secret=
INBOUND_EMAIL_SECRET=
# Recommended shared secret for /api/public/hooks/run-daily-search
RUN_DAILY_SEARCH_SECRET=

# --- Inbound email/source docs defaults ---
# Public webhook URL shown in the Sources UI/docs for your deployed app
INBOUND_EMAIL_WEBHOOK_URL=
# Forwarding inbox/address shown in the Sources UI/docs
INBOUND_FORWARDING_ADDRESS=
